{
  "name": "real-life-grind",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:preview": "serve storybook-static",
    "svelte-check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "biome check --write",
    "format": "biome format --write",
    "check": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json && vitest run && playwright test && biome check",
    "ci-check": "tsc --noEmit & svelte-check --tsconfig ./tsconfig.json & vitest run & playwright test & biome check; wait"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "1.60.0",
    "@storybook/addon-a11y": "10.4.0",
    "@storybook/addon-themes": "10.4.0",
    "@storybook/svelte-vite": "10.4.0",
    "@storybook/test-runner": "0.24.4",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "firebase-tools": "15.18.0",
    "jsdom": "^29.1.1",
    "lefthook": "2.1.6",
    "serve": "14.2.6",
    "storybook": "10.4.0",
    "svelte-check": "4.4.8",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.6"
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "firebase": "^12.13.0",
    "melt": "^0.44.0",
    "svelte": "^5.55.7"
  }
}
